#!/usr/bin/env bash
# ============================================================
# yu — 双AI智能体协作终端
# Yu's Unified Agent Stack: Hermes + Claude Code Split Screen
# ============================================================
set -e

YU_HOME="${YU_HOME:-$HOME/.yu-stack}"
YU_SESSION="yu-collab"

# ─── Colors ────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; NC='\033[0m'

info()  { echo -e "${CYAN}ℹ${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
err()   { echo -e "${RED}✗${NC} $1" >&2; }

# ─── Help ──────────────────────────────────────────────────
show_help() {
  cat <<EOF
${CYAN}yu${NC} — 双AI智能体协作终端

USAGE:
  yu                   启动/进入协作终端
  yu --setup           运行首次安装
  yu --layout          切换分屏布局
  yu --reset           重建协作会话
  yu --task <描述>     设置当前任务
  yu --status          查看工作区状态
  yu --help            显示此帮助

WHAT IT DOES:
  左侧: Hermes（分析、规划、决策、学习）
  右侧: Claude Code（编码、实现、执行）
  共享工作区: ~/.yu-stack/task.md 自动同步

SKILL SYSTEMS (自动加载):
  ├─ The Agency (144 Expert Roles) — via Claude Code
  └─ gstack (43 Dev Workflows) — via Hermes

ETHOS: Boil the Lake — 做完整的事，不抄捷径。
        Search Before Building — 有现成的直接用。
EOF
  exit 0
}

# ─── Check requirements ────────────────────────────────────
check_reqs() {
  local missing=0
  command -v tmux >/dev/null 2>&1 || { err "tmux not found"; missing=1; }
  command -v hermes >/dev/null 2>&1 || { err "hermes not found — run 'yu --setup'"; missing=1; }
  command -v claude >/dev/null 2>&1 || { warn "claude not found — right pane will show placeholder"; }
  [ $missing -eq 1 ] && exit 1
}

# ─── Workspace ─────────────────────────────────────────────
init_workspace() {
  mkdir -p "$YU_HOME"
  [ -f "$YU_HOME/task.md" ] || cat > "$YU_HOME/task.md" <<'TASK'
# 🎯 当前任务
（在此描述你要做的事情）

## 上下文
（项目背景、相关文件路径）

## 交付物
（期望的输出结果）
TASK
  ok "workspace ready at $YU_HOME"
}

set_task() {
  echo "$*" > "$YU_HOME/current_task.txt"
  echo "# 🎯 当前任务" > "$YU_HOME/task.md"
  echo "" >> "$YU_HOME/task.md"
  echo "$*" >> "$YU_HOME/task.md"
  echo "" >> "$YU_HOME/task.md"
  echo "## 上下文" >> "$YU_HOME/task.md"
  echo "" >> "$YU_HOME/task.md"
  echo "## 交付物" >> "$YU_HOME/task.md"
  ok "task set: $*"
}

# ─── tmux session ──────────────────────────────────────────
launch_session() {
  local task_desc
  task_desc="$(cat "$YU_HOME/current_task.txt" 2>/dev/null || echo '🚀 yu-stack ready')"

  # Kill stale session
  tmux kill-session -t "$YU_SESSION" 2>/dev/null || true
  sleep 0.3

  # Create new session with two panes
  tmux new-session -d -s "$YU_SESSION" \; \
    send-keys "export YU_MODE=hermes; echo ''; echo '  ╔══════════════════════════════════════════╗'; echo '  ║     🧠 Hermes  — 分析 · 规划 · 学习     ║'; echo '  ║     🛠️  Skills: Agency 144 + gstack 43   ║'; echo '  ╚══════════════════════════════════════════╝'; echo ''; cat '$YU_HOME/task.md' 2>/dev/null; echo ''; hermes" Enter \; \
    split-window -h \; \
    send-keys "export YU_MODE=claude; echo ''; echo '  ╔══════════════════════════════════════════╗'; echo '  ║     🤖 Claude Code — 编码 · 实现 · 执行  ║'; echo '  ║     🎭  Agency: 144 Expert Roles Active  ║'; echo '  ╚══════════════════════════════════════════╝'; echo ''; cat '$YU_HOME/task.md' 2>/dev/null; echo ''; echo 'Skills loaded:'; ls ~/.claude/agents/ 2>/dev/null | head -5 || echo '  (run yu-stack setup to install Agency Agents)'; echo ''; claude" Enter \; \
    select-layout even-horizontal \; \
    set-option -g remain-on-exit on \; \
    set-option -g default-command '' \; \
    set-option -g pane-border-status top \; \
    set-option -g pane-border-format ' #I:#W ' \; \
    rename-window 'yu-stack' \; \
    set-window-option -g mode-keys vi \; \

  ok "yu-collab session created (2 panes)"
}

# ─── Layout toggle ─────────────────────────────────────────
cycle_layout() {
  local current_layout
  current_layout=$(tmux list-windows -t "$YU_SESSION" -F "#{window_layout}" 2>/dev/null | head -1)
  if echo "$current_layout" | grep -q '{'; then
    tmux select-layout -t "$YU_SESSION" tiled 2>/dev/null || true
  else
    tmux select-layout -t "$YU_SESSION" even-horizontal 2>/dev/null || true
  fi
}

# ─── Status ────────────────────────────────────────────────
show_status() {
  echo -e "${CYAN}═══════════════════════════════════════════${NC}"
  echo -e "${CYAN}  Yu Stack — Workspace Status${NC}"
  echo -e "${CYAN}═══════════════════════════════════════════${NC}"
  echo ""
  echo -e "  ${GREEN}Skills loaded:${NC}"
  echo -e "    Agency: $(ls ~/.hermes/skills/agency-agents* 2>/dev/null | wc -l | tr -d ' ') / 144 roles"
  echo -e "    gstack: $(ls ~/.hermes/skills/ | grep gstack | wc -l | tr -d ' ') / 43 workflows"
  echo ""
  echo -e "  ${GREEN}Current task:${NC}"
  head -3 "$YU_HOME/task.md" 2>/dev/null || echo "    (none)"
  echo ""
  echo -e "  ${GREEN}tmux session:${NC}"
  tmux ls 2>/dev/null | grep "$YU_SESSION" || echo "    (not running)"
  echo ""
  echo -e "  ${GREEN}Workspace:${NC}"
  ls -la "$YU_HOME/" 2>/dev/null
  echo ""
  echo -e "  ${GREEN}Shared files:${NC}"
  ls -lt ~/Desktop/共享文件/ 2>/dev/null | head -5 || echo "    (no shared files)"
  echo ""
  echo -e "${CYAN}═══════════════════════════════════════════${NC}"
}

# ─── Main ──────────────────────────────────────────────────
case "${1:-}" in
  --help|-h)    show_help ;;
  --setup)      check_reqs; init_workspace; ok "setup complete"; exit 0 ;;
  --layout)     cycle_layout; exit 0 ;;
  --reset)      tmux kill-session -t "$YU_SESSION" 2>/dev/null || true; launch_session; echo "→ tmux attach -t $YU_SESSION"; exit 0 ;;
  --task)       shift; [ -z "$*" ] && { err "usage: yu --task <description>"; exit 1; }; set_task "$*"; exit 0 ;;
  --status|-s)  show_status; exit 0 ;;
  *)            check_reqs; init_workspace
                if tmux has-session -t "$YU_SESSION" 2>/dev/null; then
                  tmux attach -t "$YU_SESSION"
                else
                  launch_session
                  echo ""
                  echo -e "  ${GREEN}→ Run:${NC} tmux attach -t $YU_SESSION"
                  echo ""
                fi
                ;;
esac
